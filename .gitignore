# Python
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# Local editor/system files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs and generated outputs
logs/*
!logs/.gitkeep

# Captured images from future camera workflows
captures/*
!captures/.gitkeep

# Trained model checkpoints can be large; keep the folder, not generated weights.
models/*
!models/.gitkeep

# Keep the dataset folder structure, but do not commit image datasets.
data/**/*
!data/**/
!data/**/.gitkeep

# Temporary files
*.tmp
*.log

# STM32CubeIDE generated build and workspace output
firmware/stm32/**/Debug/
firmware/stm32/**/Release/
firmware/stm32/**/.settings/
firmware/stm32/**/*.elf
firmware/stm32/**/*.bin
firmware/stm32/**/*.map
firmware/stm32/**/*.list
firmware/stm32/**/*.o
firmware/stm32/**/*.d
